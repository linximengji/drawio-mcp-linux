<mxfile host="test">
  <diagram name="model-routing" id="routing">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1150">
      <root>
        <mxCell id="0" />
